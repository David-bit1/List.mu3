# ============================================================
# Variables de entorno del backend (Render)
# Copia a `.env` localmente o define estas mismas en Render -> Environment.
# NUNCA subas el `.env` real.
# ============================================================

# Puerto (Render lo inyecta automáticamente; útil para local)
PORT=5050

# Supabase (PostgreSQL)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Service role key (solo backend). Permite escritura sin RLS.
SUPABASE_SERVICE_KEY=TU_SERVICE_ROLE_KEY
# Clave pública (respaldo)
SUPABASE_ANON_KEY=TU_ANON_KEY

# TMDb API (v3 key)
TMDB_API_KEY=TU_TMDB_API_KEY

# Autenticación del panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-clave
# Frase para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia-este-secreto-jwt

# CORS: origen del frontend (Vercel). Separar varios con comas.
# Dejar vacío para permitir cualquiera (no recomendado en producción).
CORS_ORIGIN=
