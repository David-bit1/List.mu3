# ============================================================
# Variables de entorno — copia este archivo a `.env` y completa.
# En Vercel añade estas mismas variables en Project → Settings → Environment Variables.
# NUNCA subas tu `.env` real al repositorio.
# ============================================================

# Puerto local (Vercel lo ignora y usa el suyo)
PORT=5050

# Supabase (PostgreSQL)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Clave de servicio (service_role). SOLO backend. Permite escritura sin RLS.
# En Vercel usa esta variable, no la anon key, para poder insertar/actualizar.
SUPABASE_SERVICE_KEY=TU_SERVICE_ROLE_KEY
# Clave pública (opcional, se usa como respaldo si falta la anterior)
SUPABASE_ANON_KEY=TU_ANON_KEY

# TMDb API (v3 key)
TMDB_API_KEY=TU_TMDB_API_KEY

# Autenticación del panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-clave
# Frase para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia-este-secreto-jwt
