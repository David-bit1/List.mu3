# ============================================================
# Variables de entorno — copia este archivo a `.env` y completa.
# NUNCA subas tu `.env` real al repositorio.
# Cada servicio también tiene su propio `.env.example`:
#   - backend/.env.example  (Render)
#   - frontend/.env.example (Vercel: VITE_API_URL)
# ============================================================

# ---------------- BACKEND (Render) ----------------
# Puerto (Render lo inyecta automáticamente)
PORT=5050

# Supabase (PostgreSQL)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Clave de servicio (service_role). SOLO backend. Permite escritura sin RLS.
SUPABASE_SERVICE_KEY=TU_SERVICE_ROLE_KEY
# Clave pública (respaldo)
SUPABASE_ANON_KEY=TU_ANON_KEY

# TMDb API (v3 key)
TMDB_API_KEY=TU_TMDB_API_KEY

# Autenticación del panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-clave
# Frase para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia-este-secreto-jwt

# CORS: origen del frontend (URL de Vercel). Separar varios con comas.
# Vacío = permitir cualquiera (no recomendado en producción).
CORS_ORIGIN=

# ---------------- FRONTEND (Vercel) ----------------
# URL del backend en Render (sin barra final). Ej:
# VITE_API_URL=https://iptv-backend.onrender.com
VITE_API_URL=
